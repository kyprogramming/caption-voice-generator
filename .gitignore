# =============================================================
# .gitignore — Caption & Voice Studio
# =============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
pip-wheel-metadata/

# ── Virtual environments ─────────────────────────────────────
venv/
.venv/
env/
.env/
myenv/
venv*/
ENV/
myenv/

# ── Environment / secrets ────────────────────────────────────
.env
.env.*
!.env.example        # keep the example template if you have one
*.pem
*.key
secrets.json

# ── Generated runtime folders ────────────────────────────────
# These are created automatically by the app at runtime.
# Never commit user uploads, generated videos, or audio.
temp/
videos/
audio/

# ── TTS model cache (Coqui / HuggingFace) ───────────────────
# Models are downloaded automatically on first run — large files
tts_models/
.local/share/tts/
~/.local/share/tts/

# ── OS junk ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / editor ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
log/

# ── Test / coverage ──────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Patch / backup files ─────────────────────────────────────
*.bak
*.orig
*.patch
patch_tts.py         # one-off fix script, not needed in repo

# ── Large media files — never commit these ───────────────────
*.mp4
*.mp3
*.wav
*.avi
*.mov
*.mkv
*.flac
*.aac
*.ogg
*.webm

# ── Fonts (optional: commit fonts if you want them in repo) ──
# Comment out the line below if you want fonts tracked by git
# fonts/*.ttf
# fonts/*.otf

# ── Node (if any frontend tooling is added later) ────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*